# ─── Identidade do Agente ──────────────────────────────────────────────────────
JWT_TOKEN=eyJhbGciOiJSUzI1NiJ9...   # Gerado pelo portal em Clientes → Gerar Token
CNPJ=12.345.678/0001-99              # CNPJ do cliente (mesmo do JWT)

# ─── PostgreSQL local (banco do cliente) ───────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_USER=usuario
PG_PASSWORD=senha
PG_DBNAME=banco_do_cliente

# ─── EMQX Cloud SGA ────────────────────────────────────────────────────────────
MQTT_BROKER=mqtts://emqx.sgapetro.cloud:8883
MQTT_CLIENT_ID=sga-agent-{uuid}

# ─── Cache / Audit ─────────────────────────────────────────────────────────────
SQLITE_PATH=./data/cache.db

# ─── Comportamento ─────────────────────────────────────────────────────────────
QUERY_TIMEOUT_MS=30000
HEARTBEAT_INTERVAL_S=60
LOG_LEVEL=info
